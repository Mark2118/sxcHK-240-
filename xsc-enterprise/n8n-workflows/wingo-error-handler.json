        "jsonBody": "={\"msg_type\":\"text\",\"content\":{\"text\":\"❌ n8n工作流执行失败\\n\\n工作流：{{ $json.workflow.name }}\\n节点：{{ $json.execution.lastNodeExecuted }}\\n错误：{{ $json.execution.error.message }}\\n时间：{{ $now.toFormat('yyyy-MM-dd HH:mm:ss') }}\"}}",
        "options": { "retry": { "retry": true, "maxRetries": 3, "waitBetweenRetries": 2000 } }
