# ==================== WinGo 学情洞察 — 环境配置模板 ====================
# 复制为 .env 后填入真实值
# 注意：.env 文件受 .gitignore 保护，不会进入版本控制

# --- 服务器 -----------------------------------------------------
NODE_ENV=production
PORT=3002
HOSTNAME=0.0.0.0

# --- 数据库 -----------------------------------------------------
DATABASE_URL=file:./data/wingo-xsc.db

# --- AI 引擎 ----------------------------------------------------
AI_PROVIDER=minimax
AI_API_KEY=
AI_BASE_URL=https://api.minimaxi.com/v1
AI_MODEL=MiniMax-M2.7-highspeed
AI_TIMEOUT=120

# --- 百度 OCR ---------------------------------------------------
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# --- OpenMAIC ---------------------------------------------------
OPENMAIC_URL=http://100.106.90.55:3000

# --- n8n 营销自动化 ---------------------------------------------
N8N_WEBHOOK_URL=http://100.106.90.55:5678/webhook/wingo-events

# --- 认证 -------------------------------------------------------
JWT_SECRET=xsc-enterprise-jwt-secret-2026
MASTER_KEY=xsc-admin-2026

# --- 应用基础 ---------------------------------------------------
APP_NAME=WinGo 学情洞察
NEXT_PUBLIC_BASE_URL=http://100.106.90.55:3002

# --- 飞书通知（可选）---------------------------------------------
FEISHU_WEBHOOK_URL=

# --- 微信生态 ---------------------------------------------------
# 微信登录授权 (src/app/api/auth/wechat/route.ts)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 微信 JS-SDK / 支付 (src/lib/wechat-jssdk.ts, src/lib/wechat-pay.ts)
# ⚠️ 注意：代码中同时使用了 WECHAT_APP_ID 和 WECHAT_APPID，两者都需配置
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_TEMPLATE_MSG_ID=
# 微信支付
WECHAT_PAY_MOCK=true
WECHAT_MCHID=
WECHAT_APIV3_KEY=
WECHAT_CERT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_PAY_NOTIFY_URL=http://100.106.90.55:3002/xsc/api/orders/callback
