# ==================== WinGo 学情洞察 — 环境配置 ====================

# Database
DATABASE_URL="file:./dev.db"

# Baidu OCR
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# AI Provider (MiniMax)
AI_PROVIDER=minimax
AI_API_KEY=
AI_BASE_URL=https://api.minimaxi.com/v1
AI_MODEL=MiniMax-M2.7-highspeed

# Auth
JWT_SECRET=xsc-enterprise-secret-key-2026
MASTER_KEY=xsc-admin-2026

# OpenMAIC
OPENMAIC_URL=http://host.docker.internal:3001

# App
APP_NAME="WinGo 学情洞察"
APP_PORT=3000

# WeChat
WECHAT_APPID=                    # 微信公众号 AppID（必须填，用于模板消息）
WECHAT_SECRET=                   # 微信公众号 Secret（必须填）
WECHAT_TEMPLATE_MSG_ID=          # 传统模板消息ID（已配置）
WECHAT_MCHID=                    # 微信支付商户号
WECHAT_APIV3_KEY=                # 微信支付 APIv3 密钥
WECHAT_CERT_SERIAL_NO=           # 微信支付证书序列号
WECHAT_PRIVATE_KEY_BASE64=       # 微信支付私钥（Base64编码）
WECHAT_PAY_NOTIFY_URL=           # 支付回调URL

# n8n Marketing Automation（Mac Tailscale）
N8N_WEBHOOK_URL=http://100.106.90.55:5678/webhook/wingo-events

# Dify AI (可选增强，Mac Tailscale)
DIFY_API_URL=http://100.106.90.55:8080
DIFY_API_KEY=                    # Dify 应用的 API Key（如需AI生成文案则填）
