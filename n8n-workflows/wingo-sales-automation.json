          "rules": [
            { "value": "={{ $json.event }}", "value2": "user_registered", "operation": "equal" },
            { "value": "={{ $json.event }}", "value2": "free_quota_exhausted", "operation": "equal" },
            { "value": "={{ $json.event }}", "value2": "payment_success", "operation": "equal" },
            { "value": "={{ $json.event }}", "value2": "report_generated", "operation": "equal" }
          ]
        }
      }
    },
