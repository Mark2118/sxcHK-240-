      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [450, 100],
      "parameters": {
        "options": { "retry": { "retry": true, "maxRetries": 3, "waitBetweenRetries": 2000 } },
        "respondWith": "json",
        "responseBody": "=OK"
      }
    },
    {
      "id": "0e12b292-681d-4717-a64e-fd05af137432",
      "name": "Event Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2.1,
      "position": [450, 300],
      "parameters": {
        "mode": "rules",
